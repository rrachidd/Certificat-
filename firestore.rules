rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    
    function isValidInstitutionSettings(data, userId) {
      return data.keys().size() >= 1
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && (data.userId == userId || data.userId == null);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidInstitutionSettings(incoming(), userId);
      allow update: if isOwner(userId) && isValidInstitutionSettings(incoming(), userId);
      
      match /archive/{archiveId} {
        allow read, write: if isOwner(userId);
      }
      match /students/{studentId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
