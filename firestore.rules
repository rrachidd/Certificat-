rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    
    function isValidInstitutionSettings(data, userId) {
      return data.keys().size() >= 2
        && data.keys().hasAny(['name', 'userId'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.userId == userId
        && (data.get('academy', '') is string) && (data.get('academy', '').size() <= 200)
        && (data.get('province', '') is string) && (data.get('province', '').size() <= 200)
        && (data.get('refNumber', '') is string) && (data.get('refNumber', '').size() <= 200)
        && (data.get('updatedAt', request.time) == request.time);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidInstitutionSettings(incoming(), userId);
      allow update: if isOwner(userId) && isValidInstitutionSettings(incoming(), userId)
                    && incoming().userId == existing().userId;
    }
  }
}
